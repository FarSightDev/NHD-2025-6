import socket
import subprocess
import ipaddress
import re
from zeroconf import Zeroconf, ServiceBrowser
import time
from datetime import datetime
from scapy.all import sniff, DNS, DNSQR, IP
import threading

mdns_hosts = {}
seen_devices = {}
mac_vendors = {}
ip_domains = {}

with open("/usr/share/nmap/nmap-mac-prefixes", "r", errors="ignore") as f:
    for line in f:
        if line.strip() and not line.startswith("#"):
            prefix, vendor = line.strip().split(None, 1)
            mac_vendors[prefix.upper()] = vendor

class MDNSListener:
    def add_service(self, zeroconf, service_type, name):
        try:
            info = zeroconf.get_service_info(service_type, name)
            if info:
                for addr in info.addresses:
                    ip = socket.inet_ntoa(addr)
                    mdns_hosts[ip] = info.server.rstrip(".")
        except:
            pass

    def update_service(self, zeroconf, service_type, name):
        self.add_service(zeroconf, service_type, name)

    def remove_service(self, zeroconf, service_type, name):
        pass

def get_ip_range():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.connect(("8.8.8.8", 80))
    local_ip = s.getsockname()[0]
    s.close()
    output = subprocess.check_output(["ip", "addr"], text=True)
    for line in output.splitlines():
        if local_ip in line:
            match = re.search(r'inet (\d+\.\d+\.\d+\.\d+)/(\d+)', line)
            if match:
                ip = match.group(1)
                cidr = match.group(2)
                return ipaddress.ip_network(f"{ip}/{cidr}", strict=False)
    raise RuntimeError("Network range not found")

def scan_network(ip_range):
    return subprocess.check_output(["nmap", "-sn", str(ip_range)], text=True)

def parse_nmap_output(output):
    devices = []
    current = {}
    for line in output.splitlines():
        if line.startswith("Nmap scan report for"):
            if current:
                devices.append(current)
            parts = line.replace("Nmap scan report for ", "")
            if "(" in parts and ")" in parts:
                hostname, ip = parts.split(" (")
                ip = ip.strip(")")
            else:
                hostname = None
                ip = parts
            current = {"ip": ip, "hostname": hostname}
        elif "MAC Address:" in line:
            current["mac"] = line.split()[2]
    if current:
        devices.append(current)
    return devices

def reverse_dns_lookup(ip):
    try:
        return socket.gethostbyaddr(ip)[0]
    except:
        return None

def mac_vendor_lookup(mac):
    if not mac:
        return "unknown"
    prefix = mac.upper().replace(":", "")[:6]
    return mac_vendors.get(prefix, "unknown")

def ip_sort_key(ip):
    return tuple(int(x) for x in ip.split("."))

def dns_sniffer(pkt):
    if pkt.haslayer(DNS) and pkt.haslayer(IP):
        if pkt[DNS].qr == 0:
            domain = pkt[DNSQR].qname.decode(errors="ignore").rstrip(".")
            src_ip = pkt[IP].src
            ip_domains.setdefault(src_ip, set()).add(domain)

def start_sniffing():
    sniff(filter="udp port 53", prn=dns_sniffer, store=False)

zeroconf = Zeroconf()
listener = MDNSListener()

service_types = [
    "_http._tcp.local.",
    "_workstation._tcp.local.",
    "_ssh._tcp.local.",
    "_device-info._tcp.local."
]

browsers = [ServiceBrowser(zeroconf, st, listener) for st in service_types]

ip_range = get_ip_range()

threading.Thread(target=start_sniffing, daemon=True).start()

print("timestamp,ip,mac,vendor,hostname,websites")

while True:
    output = scan_network(ip_range)
    devices = parse_nmap_output(output)
    current_scan = {}
    for d in devices:
        ip = d.get("ip", "")
        mac = d.get("mac", "unknown")
        hostname = d.get("hostname") or mdns_hosts.get(ip) or reverse_dns_lookup(ip) or "unknown"
        vendor = mac_vendor_lookup(mac)
        websites = ";".join(sorted(ip_domains.get(ip, []))) or "unknown"
        device_key = f"{ip}-{mac}"
        current_scan[device_key] = {"hostname": hostname, "vendor": vendor, "websites": websites}
        if device_key not in seen_devices or seen_devices[device_key] != current_scan[device_key]:
            timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            print(f"{timestamp},{ip},{mac},{vendor},{hostname},{websites}")
            seen_devices[device_key] = current_scan[device_key]
    disappeared = set(seen_devices.keys()) - set(current_scan.keys())
    for device_key in sorted(disappeared, key=lambda x: ip_sort_key(x.split("-", 1)[0])):
        del seen_devices[device_key]
    time.sleep(30)
