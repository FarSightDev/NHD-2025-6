import socket
import subprocess
import ipaddress
import re   
from ipwhois import IPWhois   


def get_ip_range():   
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)   
    s.connect(("8.8.8.8", 80))   
    local_ip = s.getsockname()[0]   
    s.close()   
   
    output = subprocess.check_output(["ip", "addr"], text=True)   
   
    for line in output.splitlines():   
        if local_ip in line:   
            match = re.search(r'inet (\d+\.\d+\.\d+\.\d+)/(\d+)', line)   
            if match:   
                ip = match.group(1)   
                cidr = match.group(2)   
                return ipaddress.ip_network(f"{ip}/{cidr}", strict=False)   
   
    raise RuntimeError("Network range not found")   
   
   
def scan_network(ip_range):   
    return subprocess.check_output(   
        ["nmap", "-sn", str(ip_range)],   
        text=True   
    )   
   
   
def parse_nmap_output(output):   
    devices = []     
    current = {}   
   
    for line in output.splitlines():   
        if line.startswith("Nmap scan report for"):   
            if current:   
                devices.append(current)   
            parts = line.replace("Nmap scan report for ", "")   
            if "(" in parts and ")" in parts:   
                hostname, ip = parts.split(" (")   
                ip = ip.strip(")")   
            else:   
                hostname = None   
                ip = parts   
            current = {"ip": ip, "hostname": hostname}   
        elif "MAC Address:" in line:   
            current["mac"] = line.split()[2]   
   
    if current:   
        devices.append(current)   
   
    return devices   
   
   
def extract_best_name(data):   
    candidates =   []  
   
    net = data.get("network", {})   
    if net.get("name"):   
        candidates.append(net["name"])   
    if net.get("handle"):   
        candidates.append(net["handle"])   
   
    for entity in data.get("entities",  ):   
        obj = data.get("objects", {}).get(entity, {})   
        roles = obj.get("roles",  )   
        if not set(roles) & {"registrant", "administrative", "technical"}:   
            continue   
        vcard = obj.get("vcardArray",  )   
        if len(vcard) == 2:   
            for item in vcard[1]:   
                if item[0] in {"fn", "org"} and item[3]:   
                    candidates.append(item[3])   
   
    for name in candidates:   
        if name and len(name) > 2 and not name.lower().startswith(("whois", "ripe", "arin", "apnic", "lacnic", "afrinic")):   
            return name.strip()   
   
    return "unknown"   
   
   
def extract_phone(data):   
    for entity in data.get("entities",  ):   
        obj = data.get("objects", {}).get(entity, {})   
        vcard = obj.get("vcardArray",  )   
        if len(vcard) == 2:   
            for item in vcard[1]:   
                if item[0] == "tel" and item[3]:   
                    return item[3]   
    return "unknown"   
   
   
def ipwhois_lookup(ip):   
    try:   
        data = IPWhois(ip).lookup_rdap()   
        return extract_best_name(data), extract_phone(data)   
    except Exception:   
        return "unknown", "unknown"   
   
   
ip_range = get_ip_range()   
output = scan_network(ip_range)   
devices = parse_nmap_output(output)   
   
for d in devices:   
    ip = d.get("ip", "")   
    mac = d.get("mac", "unknown")   
    hostname = d.get("hostname", "unknown")   
    owner, phone = ipwhois_lookup(ip)   
    print(f"{ip} | {hostname} | {mac} | {owner} | {phone}")
